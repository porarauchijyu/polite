<Window x:Class="RssGenerator.AddSiteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add New Feed Target" Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PrimaryBrush}"
        WindowStyle="None" AllowsTransparency="True" BorderThickness="1" BorderBrush="#334155">
    
    <Border CornerRadius="12" Background="{StaticResource PrimaryBrush}" BorderThickness="1" BorderBrush="#334155">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <DockPanel Grid.Row="0" LastChildFill="False">
                <TextBlock x:Name="WindowTitle" Text="Add New Site" Foreground="White" FontSize="20" FontWeight="Bold"/>
                <Button Content="✕" Click="OnCancelClick" DockPanel.Dock="Right" Background="Transparent" Foreground="{StaticResource DimTextBrush}" BorderThickness="0" FontSize="18"/>
            </DockPanel>

            <!-- Inputs -->
            <StackPanel Grid.Row="1" Margin="0,20">
                <TextBlock Text="Site Name (保存名)" Foreground="{StaticResource DimTextBrush}" Margin="0,0,0,8"/>
                <TextBox x:Name="NameTextBox" Padding="10" Background="{StaticResource SecondaryBrush}" Foreground="White" BorderThickness="1" BorderBrush="#334155" Margin="0,0,0,15">
                     <TextBox.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock Text="Target URL" Foreground="{StaticResource DimTextBrush}" Margin="0,0,0,8"/>
                <TextBox x:Name="UrlTextBox" Padding="10" Background="{StaticResource SecondaryBrush}" Foreground="White" BorderThickness="1" BorderBrush="#334155">
                     <TextBox.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                    </TextBox.Resources>
                </TextBox>
                
                <TextBlock Text="Wait Time (巡回時の待機秒数)" Foreground="{StaticResource DimTextBrush}" Margin="0,15,0,8"/>
                <TextBox x:Name="WaitTimeTextBox" Text="3" Padding="10" Background="{StaticResource SecondaryBrush}" Foreground="White" BorderThickness="1" BorderBrush="#334155">
                     <TextBox.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                    </TextBox.Resources>
                </TextBox>

                <Button Content="Analyze Site Structure (自動解析)" Click="OnAnalyzeClick" Margin="0,15,0,0" Padding="0,10" Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0"/>
                <Button Content="Open Visual Selector (手動で指定)" Click="OnVisualSelectClick" Margin="0,8,0,0" Padding="0,8" Background="Transparent" Foreground="{StaticResource AccentBrush}" BorderThickness="1" BorderBrush="{StaticResource AccentBrush}"/>
            </StackPanel>

            <!-- Analysis Results -->
            <Grid Grid.Row="2" Margin="0,10">
                <StackPanel x:Name="ResultsPanel" Visibility="Collapsed">
                    <TextBlock Text="Automatic Detection Results" Foreground="{StaticResource DimTextBrush}" Margin="0,0,0,8"/>
                    <ListView x:Name="InferenceListView" Height="150" Background="{StaticResource SecondaryBrush}" BorderThickness="0" Margin="0,0,0,10">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <TextBlock Text="{Binding SampleTitle}" Foreground="White" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Score, StringFormat='Score: {0}'}" FontSize="10" Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
                
                <TextBlock x:Name="StatusLabel" Text="Enter URL to begin analysis..." Foreground="{StaticResource DimTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Visible"/>
                <ProgressBar x:Name="LoadingBar" IsIndeterminate="True" Height="4" VerticalAlignment="Center" Visibility="Collapsed"/>
            </Grid>

            <!-- Footer Actions -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Cancel" Click="OnCancelClick" Width="80" Padding="0,8" Background="Transparent" Foreground="{StaticResource DimTextBrush}" BorderThickness="0"/>
                <Button x:Name="SaveButton" Content="Register Site" Click="OnSaveClick" Width="120" Padding="0,8" Background="#10B981" Foreground="White" BorderThickness="0" IsEnabled="False" Margin="15,0,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
